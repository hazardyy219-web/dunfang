                                        <button class="subcategory-item block w-full text-left py-2 px-4 hover:bg-gray-50 rounded text-sm text-gray-600" data-subcategory="industrial-motors">Industrial Motors</button>
                                        <button class="subcategory-item block w-full text-left py-2 px-4 hover:bg-gray-50 rounded text-sm text-gray-600" data-subcategory="hydraulic-components">Hydraulic Components</button>
                                        <button class="subcategory-item block w-full text-left py-2 px-4 hover:bg-gray-50 rounded text-sm text-gray-600" data-subcategory="automation-systems">Automation Control Systems</button>
                                    </div>
                                </div>
                                
                                <!-- 全部产品 -->
                                <div class="category-item">
                                    <button class="category-toggle flex items-center justify-between w-full text-left py-3 px-4 rounded hover:bg-gray-50 transition-colors" data-category="all">
                                        <span class="font-medium">All Products</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- 右侧产品展示区 -->
                    <div class="lg:w-3/4">
                        <!-- 移动端分类标签栏 -->
                        <div class="lg:hidden mb-8">
                            <div class="category-tabs reveal overflow-x-auto pb-4">
                                <button class="category-tab active" data-category="all">All</button>
                                <button class="category-tab" data-category="metal">Metal</button>
                                <button class="category-tab" data-category="plastic">Plastic</button>
                                <button class="category-tab" data-category="rubber">Rubber</button>
                                <button class="category-tab" data-category="building">Building</button>
                                <button class="category-tab" data-category="mold">Mold</button>
                                <button class="category-tab" data-category="hardware">Hardware</button>
                                <button class="category-tab" data-category="mechanical">Electrical</button>
                            </div>
                        </div>
                        
                        <div id="products-container" class="product-grid">
                            <!-- 产品将通过JavaScript动态加载 -->
                        </div>

                        <!-- 分页 -->
                        <div id="pagination-container" class="mt-20 reveal">
                            <!-- 分页按钮将通过JavaScript动态加载 -->
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <!-- 页脚 -->
