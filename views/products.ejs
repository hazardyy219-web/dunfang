                                        <button class="subcategory-item block w-full text-left py-2 px-4 hover:bg-gray-50 rounded text-sm text-gray-600" data-subcategory="metal-stamping">Metal Stamping Dies</button>
                                    </div>
                                </div>
                                
                                <!-- 塑料制品 -->
                                <div class="category-item mb-4">
                                    <button class="category-toggle flex items-center justify-between w-full text-left py-3 px-4 rounded hover:bg-gray-50 transition-colors" data-category="plastic">
