                                </div>
                                
                                <!-- 五金配件 -->
                                <div class="category-item mb-4">
                                    <button class="category-toggle flex items-center justify-between w-full text-left py-3 px-4 rounded hover:bg-gray-50 transition-colors" data-category="hardware">
