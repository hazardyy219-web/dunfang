            },
            
            // 机电产品
            {
                id: 22,
                name: "Electrical Control Panel",
                description: "Advanced industrial automation electrical control panel.",
                image: "/images/mechanicalelectrical-images/1.jpg",
                link: "/product-mechanical-electrical-control-panel",
                category: "mechanical",
                subcategory: "electrical-panels"
            },
            {
                id: 23,
                name: "Industrial Motor",
                description: "High-quality industrial motor for heavy-duty applications.",
                image: "/images/mechanicalelectrical-images/2.jpg",
                link: "/product-mechanical-electrical-motor",
                category: "mechanical",
                subcategory: "industrial-motors"
            },
            {
                id: 24,
                name: "Hydraulic Components",
                description: "High-performance hydraulic system components for industrial machinery.",
                image: "/images/mechanicalelectrical-images/3.jpg",
                link: "/product-mechanical-electrical-hydraulic-components",
                category: "mechanical",
                subcategory: "hydraulic-components"
            },
            {
                id: 25,
                name: "Automation Control System",
                description: "Advanced automation control system for industrial processes.",
                image: "/images/mechanicalelectrical-images/4.jpg",
                link: "/product-mechanical-electrical-automation-control",
                category: "mechanical",
                subcategory: "automation-systems"
            }
        ];

        let currentPage = 1;
        let currentCategory = 'all';
        let currentSubcategory = 'all';
        const productsPerPage = 6;

        // 获取过滤后的产品
        function getFilteredProducts() {
            if (currentCategory === 'all') {
                return products;
            }
            
            let filtered = products.filter(product => product.category === currentCategory);
            
            if (currentSubcategory !== 'all') {
                filtered = filtered.filter(product => product.subcategory === currentSubcategory);
            }
            
            return filtered;
        }

        // 渲染产品
        function renderProducts(page) {
            const container = document.getElementById('products-container');
            container.innerHTML = '';
            
            const filteredProducts = getFilteredProducts();
            const start = (page - 1) * productsPerPage;
            const end = start + productsPerPage;
            const pageProducts = filteredProducts.slice(start, end);
            
            // 使用文档片段减少DOM操作
            const fragment = document.createDocumentFragment();
            
            pageProducts.forEach((product, index) => {
                const card = document.createElement('div');
                card.className = 'product-card reveal';
                card.style.transitionDelay = `${index * 0.15}s`;
                
                // 添加点击事件，使整个卡片可点击
                card.addEventListener('click', () => {
                    window.location.href = product.link;
                });
                
                const imgHtml = product.image ? 
                    `<img src="${product.image}" alt="${product.name}" onerror="this.parentElement.classList.add('image-placeholder'); this.parentElement.innerHTML='<i class=\'fas fa-image\'></i>';" loading="lazy" decoding="async">` :
                    `<div class="image-placeholder"><i class="fas fa-image"></i></div>`;
                
                card.innerHTML = `
                    <div class="product-image ${!product.image ? 'image-placeholder' : ''}">
                        ${imgHtml}
                        <span class="product-badge">${product.category}</span>
                    </div>
                    <div class="product-content">
                        <h3 class="product-title">${product.name}</h3>
                        <p class="product-desc">${product.description}</p>
                        <a href="${product.link}" class="product-btn">
                            View Details <i class="fas fa-arrow-right text-sm"></i>
                        </a>
                    </div>
                `;
                
                fragment.appendChild(card);
            });
            
            container.appendChild(fragment);
            
            // 批量添加动画类
            setTimeout(() => {
                const cards = container.querySelectorAll('.product-card');
                cards.forEach((card, index) => {
                    setTimeout(() => card.classList.add('active'), index * 50);
                });
            }, 100);
            
            renderPagination();
        }

        // 渲染分页
        function renderPagination() {
            const container = document.getElementById('pagination-container');
            const filteredProducts = getFilteredProducts();
            const totalPages = Math.ceil(filteredProducts.length / productsPerPage);
            
            if (totalPages <= 1) {
                container.innerHTML = '';
                return;
            }
            
            let html = '<div class="pagination">';
            
            for (let i = 1; i <= totalPages; i++) {
                html += `<button class="pagination-btn ${i === currentPage ? 'active' : ''}" data-page="${i}">${i}</button>`;
            }
            
            html += '</div>';
            container.innerHTML = html;
            
            container.querySelectorAll('.pagination-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    currentPage = parseInt(btn.dataset.page);
                    renderProducts(currentPage);
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                });
            });
        }

        // 分类展开/收起功能
        document.querySelectorAll('.category-toggle').forEach(toggle => {
            toggle.addEventListener('click', () => {
                const subcategories = toggle.nextElementSibling;
                const icon = toggle.querySelector('i');
                
                if (subcategories) {
                    subcategories.classList.toggle('hidden');
                    if (icon) {
                        icon.style.transform = subcategories.classList.contains('hidden') ? 'rotate(0deg)' : 'rotate(180deg)';
                    }
                }
                
                // 处理分类点击
                const category = toggle.dataset.category;
                if (category) {
                    currentCategory = category;
                    currentSubcategory = 'all';
                    currentPage = 1;
                    renderProducts(currentPage);
                }
            });
        });
        
        // 子分类筛选
        document.querySelectorAll('.subcategory-item').forEach(item => {
            item.addEventListener('click', () => {
                currentSubcategory = item.dataset.subcategory;
                currentPage = 1;
                renderProducts(currentPage);
            });
        });
        
        // 分类标签筛选
        document.querySelectorAll('.category-tab').forEach(tab => {
            tab.addEventListener('click', () => {
                document.querySelectorAll('.category-tab').forEach(t => t.classList.remove('active'));
                tab.classList.add('active');
                currentCategory = tab.dataset.category;
                currentSubcategory = 'all';
                currentPage = 1;
                renderProducts(currentPage);
            });
        });

        // 移动端菜单
        document.getElementById('menu-toggle').addEventListener('click', function() {
            document.getElementById('mobile-menu').classList.toggle('hidden');
        });

        // 滚动动画
        function initScrollReveal() {
            const reveals = document.querySelectorAll('.reveal');
            
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                    }
                });
            }, { threshold: 0.1 });
            
            reveals.forEach(el => observer.observe(el));
        }

        // 从URL获取分类参数
        function getCategoryFromUrl() {
            const urlParams = new URLSearchParams(window.location.search);
            return urlParams.get('category') || 'all';
        }

        // 初始化
        document.addEventListener('DOMContentLoaded', () => {
            // 从URL获取分类
            const urlCategory = getCategoryFromUrl();
            if (urlCategory !== 'all') {
                currentCategory = urlCategory;
                // 激活对应分类标签
                document.querySelectorAll('.category-tab').forEach(tab => {
                    if (tab.dataset.category === urlCategory) {
                        tab.classList.add('active');
                    } else {
                        tab.classList.remove('active');
                    }
                });
            }
            renderProducts(currentPage);
            initScrollReveal();
        });
    </script>
</body>
