            },
            {
                id: 19,
                name: "Handles and Knobs",
                description: "Ergonomic handles and knobs for industrial equipment.",
                image: "/images/hardwareaccessories-images/hard2.png",
                link: "/product-hardware-handles-knobs",
                category: "hardware",
                subcategory: "handles-knobs"
            },
            {
                id: 20,
                name: "Hinges",
                description: "High-quality hinges for doors, cabinets, and machinery.",
                image: "/images/hardwareaccessories-images/hard3.png",
                link: "/product-hardware-hinges",
                category: "hardware",
                subcategory: "hinges"
            },
            {
                id: 21,
                name: "Springs",
                description: "Precision springs for various mechanical applications.",
                image: "/images/hardwareaccessories-images/hard4.png",
