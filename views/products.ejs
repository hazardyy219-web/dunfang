                                        <i class="fas fa-chevron-down text-gray-400 transition-transform"></i>
                                    </button>
                                    <div class="subcategories pl-4 mt-2 hidden">
                                        <button class="subcategory-item block w-full text-left py-2 px-4 hover:bg-gray-50 rounded text-sm text-gray-600" data-subcategory="plastic-components">Plastic Components</button>
                                        <button class="subcategory-item block w-full text-left py-2 px-4 hover:bg-gray-50 rounded text-sm text-gray-600" data-subcategory="plastic-containers">Plastic Containers</button>
                                    </div>
                                </div>
                                
                                <!-- 橡胶制品 -->
                                <div class="category-item mb-4">
                                    <button class="category-toggle flex items-center justify-between w-full text-left py-3 px-4 rounded hover:bg-gray-50 transition-colors" data-category="rubber">
                                        <span class="font-medium">Rubber Products</span>
                                        <i class="fas fa-chevron-down text-gray-400 transition-transform"></i>
                                    </button>
                                    <div class="subcategories pl-4 mt-2 hidden">
