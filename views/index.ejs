<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="<%= description %>">
    <meta name="keywords" content="<%= keywords %>">
    <title><%= title %></title>
    <link rel="icon" href="/images/logo1.png" type="image/png">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/navbar.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        
        :root {
            --primary: #9c8b7a;
            --primary-light: #d4c4b4;
            --primary-dark: #7a6a5a;
            --accent: #b8a898;
            --dark: #2a2a2a;
            --gray-dark: #5a5a5a;
            --gray: #8a8a8a;
            --gray-light: #b8b8b8;
            --bg-dark: #1a1a1a;
            --bg-cream: #faf9f7;
            --bg-warm: #f5f3f0;
            --bg-light: #ffffff;
            --border: #e8e6e3;
            --shadow: rgba(0, 0, 0, 0.03);
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            color: var(--dark);
            line-height: 1.7;
            background-color: var(--bg-cream);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }
        
        /* 导航栏 */
        .nav-container {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(30px);
            border-bottom: 1px solid var(--border);
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .nav-link {
            position: relative;
            color: var(--gray-dark);
            font-weight: 500;
            font-size: 0.9rem;
            letter-spacing: 0.02em;
            padding: 0.75rem 0;
            transition: color 0.4s ease;
        }
        
        .nav-link::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 0;
            height: 1px;
            background: var(--primary);
            transition: width 0.4s ease, left 0.4s ease;
        }
        
        .nav-link:hover {
            color: var(--primary);
        }
        
        .nav-link:hover::after,
        .nav-link.active::after {
            width: 100%;
        }
        
        .nav-link.active {
            color: var(--primary);
        }
        
        /* Hero区域 */
        .hero {
            background: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.7)), url('/images/banner1.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            min-height: 70vh;
            display: flex;
            align-items: center;
            position: relative;
            overflow: hidden;
        }
        
        .hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: 
                radial-gradient(circle at 30% 70%, rgba(184, 166, 122, 0.08) 0%, transparent 60%),
                radial-gradient(circle at 70% 30%, rgba(201, 184, 150, 0.06) 0%, transparent 50%);
        }
        
        /* 按钮样式 */
        .btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 0.75rem;
            background: var(--primary);
            color: white;
            padding: 1rem 2.5rem;
            border-radius: 4px;
            font-weight: 500;
            font-size: 0.95rem;
            letter-spacing: 0.03em;
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            border: none;
            cursor: pointer;
        }
        
        .btn-primary:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(184, 166, 122, 0.2);
        }
        
        .btn-outline {
            display: inline-flex;
            align-items: center;
            gap: 0.75rem;
            border: 1px solid rgba(255, 255, 255, 0.25);
            color: white;
            padding: 1rem 2.5rem;
            border-radius: 4px;
            font-weight: 500;
            font-size: 0.95rem;
            letter-spacing: 0.03em;
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            background: transparent;
            cursor: pointer;
        }
        
        .btn-outline:hover {
            background: rgba(255, 255, 255, 0.08);
            border-color: rgba(255, 255, 255, 0.4);
        }
        
        /* 特性卡片 */
        .feature-card {
            background: var(--bg-light);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 3rem 2.5rem;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            cursor: pointer;
            display: block;
            text-decoration: none;
            color: inherit;
        }
        
        .feature-card:hover {
            transform: translateY(-10px) scale(1.02);
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.1);
            border-color: var(--primary-light);
            background: #f8faff;
        }
        
        .feature-card:hover .feature-icon {
            transform: scale(1.1);
        }
        
        .feature-card:hover h3 {
            color: var(--primary);
        }
        
        .feature-icon {
            width: 56px;
            height: 56px;
            transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1.25rem;
            margin-bottom: 2rem;
        }
        
        /* 产品展示 */
        .product-showcase {
            background: var(--bg-warm);
        }
        
        /* 产品分类卡片样式 */
        .product-category-card {
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 200px;
            text-decoration: none;
            color: inherit;
            transition: transform 0.3s ease;
        }
        
        .product-category-card:hover {
            transform: translateY(-5px);
        }
        
        .product-category-image {
            width: 200px;
            height: 200px;
            background: white;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
        }
        
        .product-category-image img {
            max-width: 160px;
            max-height: 160px;
            object-fit: contain;
            transition: transform 0.3s ease;
        }
        
        .product-category-card:hover .product-category-image img {
            transform: scale(1.05);
        }
        
        /* 滚动条隐藏 */
        .scrollbar-hide {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
        
        .scrollbar-hide::-webkit-scrollbar {
            display: none;
        }
        
        /* 产品项（保留旧样式，确保其他页面不受影响） */
        .product-item {
            background: var(--bg-light);
            border-radius: 8px;
            overflow: hidden;
            border: 1px solid var(--border);
            transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .product-item:hover {
            transform: translateY(-6px);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
        }
        
        .product-image {
            height: 240px;
            background: var(--bg-warm);
            overflow: hidden;
        }
        
        .product-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .product-item:hover .product-image img {
            transform: scale(1.03);
        }
        
        /* 统计数据 */
        .stat-item {
            text-align: center;
        }
        
        .stat-number {
            font-size: 3.5rem;
            font-weight: 300;
            color: var(--primary);
            letter-spacing: -0.02em;
            margin-bottom: 0.5rem;
        }
        
        /* 页脚 */
        .footer {
            background: var(--bg-dark);
            color: var(--gray-light);
        }
        
        .footer-link {
            color: var(--gray-light);
            transition: color 0.4s ease;
        }
        
        .footer-link:hover {
            color: var(--primary-light);
        }
        
        /* 滚动动画 */
        .reveal {
            opacity: 0;
            transform: translateY(40px);
            transition: all 1s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }
        
        /* 图片占位 */
        .image-placeholder {
            background: linear-gradient(135deg, var(--bg-warm) 0%, var(--border) 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--gray);
        }
        
        .image-placeholder i {
            font-size: 3rem;
            opacity: 0.4;
        }
    </style>
</head>
<body>
    <!-- 导航栏 -->
    <%- include('partials/navbar', {currentPage: 'home'}) %>

    <main>
        <!-- Hero区域 -->
        <section class="hero pt-24">
            <div class="max-w-7xl mx-auto px-8 lg:px-12 relative z-10">
                <div class="max-w-3xl">
                    <div class="text-white">
                        <h1 class="text-4xl md:text-5xl lg:text-6xl font-light mb-6 leading-tight" style="font-weight: 300; letter-spacing: -0.02em;">
                            Precision<br>
                            <span style="color: var(--primary-light);">Machinery</span>
                        </h1>
                        <p class="text-xl text-gray-300 mb-12 leading-relaxed" style="font-weight: 300;">
                            Advanced manufacturing solutions for industrial excellence. Engineered with precision, built for performance.
                        </p>
                        <div class="flex flex-wrap gap-6">
                            <a href="/products" class="btn-primary">
                                Explore Products <i class="fas fa-arrow-right"></i>
                            </a>
                            <a href="/contact" class="btn-outline">
                                Contact Us
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- 特性展示 -->
        <section class="py-32 bg-white">
            <div class="max-w-7xl mx-auto px-8 lg:px-12">
                <div class="text-center max-w-3xl mx-auto mb-24 reveal">
                    <h2 class="text-3xl md:text-4xl font-light text-gray-900 mb-6" style="font-weight: 300; letter-spacing: -0.01em;">Why Choose Us</h2>
                    <p class="text-lg text-gray-600" style="font-weight: 300;">Delivering excellence through advanced technology and unwavering commitment to quality.</p>
                </div>
                
                <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
                    <a href="/advantage/precision" class="feature-card reveal block hover:no-underline">
                        <div class="feature-icon">
                            <i class="fas fa-cogs"></i>
                        </div>
                        <h3 class="text-xl font-medium text-gray-900 mb-4" style="font-weight: 500;">Precision Engineering</h3>
                        <p class="text-gray-600" style="font-weight: 300;">State-of-the-art manufacturing with tight tolerances and exceptional accuracy for demanding applications.</p>
                    </a>
                    
                    <a href="/advantage/quality" class="feature-card reveal block hover:no-underline" style="transition-delay: 0.15s;">
                        <div class="feature-icon">
                            <i class="fas fa-certificate"></i>
                        </div>
                        <h3 class="text-xl font-medium text-gray-900 mb-4" style="font-weight: 500;">Quality Assurance</h3>
                        <p class="text-gray-600" style="font-weight: 300;">Rigorous quality control processes ensuring every product meets international standards.</p>
                    </a>
                    
                    <a href="/advantage/global" class="feature-card reveal block hover:no-underline" style="transition-delay: 0.3s;">
                        <div class="feature-icon">
                            <i class="fas fa-globe"></i>
                        </div>
                        <h3 class="text-xl font-medium text-gray-900 mb-4" style="font-weight: 500;">Global Reach</h3>
                        <p class="text-gray-600" style="font-weight: 300;">Serving clients worldwide with reliable logistics and dedicated customer support.</p>
                    </a>
                    
                    <a href="/advantage/integration" class="feature-card reveal block hover:no-underline" style="transition-delay: 0.45s;">
                        <div class="feature-icon">
                            <i class="fas fa-industry"></i>
                        </div>
                        <h3 class="text-xl font-medium text-gray-900 mb-4" style="font-weight: 500;">Industry & Trade Integration</h3>
                        <p class="text-gray-600" style="font-weight: 300;">Integrated R&D, production, and sales capabilities providing end-to-end solutions with rapid response to customer needs.</p>
                    </a>
                </div>
            </div>
        </section>

        <!-- 产品展示 -->
        <section class="product-showcase py-32">
            <div class="max-w-7xl mx-auto px-8 lg:px-12">
                <div class="flex flex-col md:flex-row md:items-end md:justify-between mb-20 reveal">
                    <div>
                        <h2 class="text-3xl md:text-4xl font-light text-gray-900 mb-4" style="font-weight: 300; letter-spacing: -0.01em;">Featured Products</h2>
                        <p class="text-lg text-gray-600 max-w-2xl" style="font-weight: 300;">Explore our range of precision-engineered products designed for industrial excellence.</p>
                    </div>
                    <a href="/products" class="mt-8 md:mt-0 font-medium hover:opacity-80 flex items-center gap-3" style="color: var(--primary); transition: all 0.4s ease;">
                        View All Products <i class="fas fa-arrow-right text-sm"></i>
                    </a>
                </div>
                
                <div class="relative overflow-hidden">
                    <div class="flex items-center justify-between mb-8">
                        <h3 class="text-2xl font-light text-gray-900" style="font-weight: 300;">Product Categories</h3>
                        <div class="flex gap-4">
                            <button id="prev-btn" class="w-10 h-10 flex items-center justify-center border border-gray-300 rounded-full hover:bg-gray-100 transition-colors">
                                <i class="fas fa-chevron-left"></i>
                            </button>
                            <button id="next-btn" class="w-10 h-10 flex items-center justify-center border border-gray-300 rounded-full hover:bg-gray-100 transition-colors">
                                <i class="fas fa-chevron-right"></i>
                            </button>
                        </div>
                    </div>
                    
                    <div class="overflow-x-auto scrollbar-hide" id="product-slider">
                        <div class="flex gap-6 min-w-max" id="product-container">
                            <!-- Metal Products -->
                            <a href="/products?category=metal" class="product-category-card">
                                <div class="product-category-image">
                                    <img src="/images/metal-images/Flashing Forming Tool.jpg" alt="Metal Products" onerror="this.parentElement.classList.add('image-placeholder'); this.parentElement.innerHTML='<i class=\'fas fa-industry\'></i>'">
                                </div>
                                <div class="text-center mt-4">
                                    <h4 class="font-medium text-gray-900">Metal Products</h4>
                                </div>
                            </a>
                            
                            <!-- Plastic Products -->
                            <a href="/products?category=plastic" class="product-category-card">
                                <div class="product-category-image">
                                    <img src="/images/plastic-images/plastic1.png" alt="Plastic Products" onerror="this.parentElement.classList.add('image-placeholder'); this.parentElement.innerHTML='<i class=\'fas fa-cube\'></i>'">
                                </div>
                                <div class="text-center mt-4">
                                    <h4 class="font-medium text-gray-900">Plastic Products</h4>
                                </div>
                            </a>
                            
                            <!-- Mechanical & Electrical -->
                            <a href="/products?category=mechanical" class="product-category-card">
                                <div class="product-category-image">
                                    <img src="/images/mechanicalelectrical-images/1.jpg" alt="Mechanical & Electrical" onerror="this.parentElement.classList.add('image-placeholder'); this.parentElement.innerHTML='<i class=\'fas fa-bolt\'></i>'">
                                </div>
                                <div class="text-center mt-4">
                                    <h4 class="font-medium text-gray-900">Mechanical & Electrical</h4>
                                </div>
                            </a>
                            
                            <!-- Mold & Tooling -->
                            <a href="/products?category=mold" class="product-category-card">
                                <div class="product-category-image">
                                    <img src="/images/moldtooling-images/Denso Duct Grill.jpg" alt="Mold & Tooling" onerror="this.parentElement.classList.add('image-placeholder'); this.parentElement.innerHTML='<i class=\'fas fa-tools\'></i>'">
                                </div>
                                <div class="text-center mt-4">
                                    <h4 class="font-medium text-gray-900">Mold & Tooling</h4>
                                </div>
                            </a>
                            
                            <!-- Rubber Products -->
                            <a href="/products?category=rubber" class="product-category-card">
                                <div class="product-category-image">
                                    <img src="/images/rubber-images/rubber1.jpg" alt="Rubber Products" onerror="this.parentElement.classList.add('image-placeholder'); this.parentElement.innerHTML='<i class=\'fas fa-circle\'></i>'">
                                </div>
                                <div class="text-center mt-4">
                                    <h4 class="font-medium text-gray-900">Rubber Products</h4>
                                </div>
                            </a>
                            
                            <!-- Hardware Accessories -->
                            <a href="/products?category=hardware" class="product-category-card">
                                <div class="product-category-image">
                                    <img src="/images/hardwareaccessories-images/hard1.png" alt="Hardware Accessories" onerror="this.parentElement.classList.add('image-placeholder'); this.parentElement.innerHTML='<i class=\'fas fa-screwdriver\'></i>'">
                                </div>
                                <div class="text-center mt-4">
                                    <h4 class="font-medium text-gray-900">Hardware Accessories</h4>
                                </div>
                            </a>
                            
                            <!-- Building Energy Saving -->
                            <a href="/products?category=building" class="product-category-card">
                                <div class="product-category-image">
                                    <img src="/images/buildingenergysaving-images/slight.jpg" alt="Building Energy Saving" onerror="this.parentElement.classList.add('image-placeholder'); this.parentElement.innerHTML='<i class=\'fas fa-leaf\'></i>'">
                                </div>
                                <div class="text-center mt-4">
                                    <h4 class="font-medium text-gray-900">Building Energy Saving</h4>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- 统计数据 -->
        <section class="py-32 bg-white">
            <div class="max-w-7xl mx-auto px-8 lg:px-12">
                <div class="grid grid-cols-2 md:grid-cols-4 gap-16">
                    <div class="stat-item reveal">
                        <div class="stat-number">20+</div>
                        <p class="text-gray-600 mt-2" style="font-weight: 400; font-size: 0.95rem;">Years Experience</p>
                    </div>
                    <div class="stat-item reveal" style="transition-delay: 0.15s;">
                        <div class="stat-number">500+</div>
                        <p class="text-gray-600 mt-2" style="font-weight: 400; font-size: 0.95rem;">Products</p>
                    </div>
                    <div class="stat-item reveal" style="transition-delay: 0.3s;">
                        <div class="stat-number">50+</div>
                        <p class="text-gray-600 mt-2" style="font-weight: 400; font-size: 0.95rem;">Countries</p>
                    </div>
                    <div class="stat-item reveal" style="transition-delay: 0.45s;">
                        <div class="stat-number">99%</div>
                        <p class="text-gray-600 mt-2" style="font-weight: 400; font-size: 0.95rem;">Client Satisfaction</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA区域 -->
        <section class="py-32" style="background: var(--bg-dark);">
            <div class="max-w-4xl mx-auto px-8 lg:px-12 text-center reveal">
                <h2 class="text-3xl md:text-4xl font-light text-white mb-8" style="font-weight: 300; letter-spacing: -0.01em;">Ready to Get Started?</h2>
                <p class="text-xl text-gray-400 mb-12" style="font-weight: 300;">Contact us today to discuss your project requirements and discover how we can help.</p>
                <a href="/contact" class="btn-primary text-lg px-10 py-4">
                    Get in Touch <i class="fas fa-arrow-right"></i>
                </a>
            </div>
        </section>
    </main>

    <!-- 页脚 -->
    <%- include('partials/footer') %>

    <script>
        // 移动端菜单
        document.getElementById('menu-toggle').addEventListener('click', function() {
            document.getElementById('mobile-menu').classList.toggle('hidden');
        });
        
        // 滚动动画
        function initScrollReveal() {
            const reveals = document.querySelectorAll('.reveal');
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                    }
                });
            }, { threshold: 0.1 });
            
            reveals.forEach(el => observer.observe(el));
        }
        
        function initProductSlider() {
            const slider = document.getElementById('product-slider');
            const container = document.getElementById('product-container');
            const prevBtn = document.getElementById('prev-btn');
            const nextBtn = document.getElementById('next-btn');
            
            if (!slider || !container || !prevBtn || !nextBtn) return;
            
            // 点击箭头按钮滑动
            const slideAmount = 220; // 每个卡片宽度 + 间距
            
            prevBtn.addEventListener('click', () => {
                slider.scrollBy({ left: -slideAmount, behavior: 'smooth' });
            });
            
            nextBtn.addEventListener('click', () => {
                slider.scrollBy({ left: slideAmount, behavior: 'smooth' });
            });
            
            // 鼠标拖动滑动
            let isDragging = false;
            let startX;
            let scrollLeft;
            
            slider.addEventListener('mousedown', (e) => {
                isDragging = true;
                startX = e.pageX - slider.offsetLeft;
                scrollLeft = slider.scrollLeft;
                slider.style.cursor = 'grabbing';
            });
            
            slider.addEventListener('mouseleave', () => {
                isDragging = false;
                slider.style.cursor = 'grab';
            });
            
            slider.addEventListener('mouseup', () => {
                isDragging = false;
                slider.style.cursor = 'grab';
            });
            
            slider.addEventListener('mousemove', (e) => {
                if (!isDragging) return;
                e.preventDefault();
                const x = e.pageX - slider.offsetLeft;
                const walk = (x - startX) * 2;
                slider.scrollLeft = scrollLeft - walk;
            });
            
            // 触摸设备支持
            slider.addEventListener('touchstart', (e) => {
                isDragging = true;
                startX = e.touches[0].pageX - slider.offsetLeft;
                scrollLeft = slider.scrollLeft;
            });
            
            slider.addEventListener('touchend', () => {
                isDragging = false;
            });
            
            slider.addEventListener('touchmove', (e) => {
                if (!isDragging) return;
                const x = e.touches[0].pageX - slider.offsetLeft;
                const walk = (x - startX) * 2;
                slider.scrollLeft = scrollLeft - walk;
            });
        }
        
        document.addEventListener('DOMContentLoaded', function() {
            initScrollReveal();
            initProductSlider();
        });
    </script>
</body>
</html>